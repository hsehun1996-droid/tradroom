# =====================================================================
# tradroom — 환경변수 예시.  복사해서 .env 로 쓰세요.  (.env 는 절대 커밋 금지)
# 키가 없으면 시스템은 자동으로 합성 샘플 데이터로 동작합니다.
# =====================================================================

# 데이터 소스 사용 여부.  true 면 실제 API, false(기본) 면 샘플 데이터.
TRADROOM_USE_LIVE_DATA=false

# DART 전자공시 OpenAPI  (https://opendart.fss.or.kr)
DART_API_KEY=

# 한국은행 ECOS 경제통계  (https://ecos.bok.or.kr/api)
ECOS_API_KEY=

# 미 연준 FRED  (https://fred.stlouisfed.org/docs/api)
FRED_API_KEY=

# 한국투자증권 KIS Developers  (실시간/주문용, 선택)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# 저장소 위치 (기본: ./data_store)
TRADROOM_DATA_DIR=./data_store
